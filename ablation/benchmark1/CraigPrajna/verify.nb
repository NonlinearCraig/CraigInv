Cell[BoxData[{
 RowBox[{
  RowBox[{"timingResult", "=", 
   RowBox[{"Timing", "[", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"vars", "=", 
      RowBox[{"{", 
       RowBox[{"x1", ",", "x2", ",", "x3"}], "}"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"domain", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x1", "^", "2"}], "-", 
         RowBox[{"10", "^", "2"}]}], "\[LessEqual]", " ", "0"}], "&&", 
       RowBox[{
        RowBox[{
         RowBox[{"x2", "^", "2"}], "-", 
         RowBox[{"10", "^", "2"}]}], "\[LessEqual]", " ", "0"}], "&&", " ", 
       RowBox[{
        RowBox[{
         RowBox[{"x3", "^", "2"}], "-", 
         RowBox[{"10", "^", "2"}]}], "\[LessEqual]", " ", "0"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"loopCond", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"-", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x1", "-", "3"}], ")"}], "^", "2"}]}], "-", 
        RowBox[{"x2", "^", "2"}], "-", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"x3", "-", "3"}], ")"}], "^", "2"}], "+", "2"}], ">=", " ", 
       "0"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "*", "x1"}], "+", "x2"}], ")"}], "*", "0.1"}], "+", 
         "x1"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{"x1", "+", 
            RowBox[{"9", "*", "x2"}], "+", 
            RowBox[{
             RowBox[{"1", "/", "2"}], "*", "x3"}]}], ")"}], "*", "0.1"}], "+",
          "x2"}], ",", 
        RowBox[{
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"2", "*", "x2"}], "+", 
            RowBox[{"16", "*", "x3"}]}], ")"}], "*", "0.1"}], "+", "x3"}]}], 
       "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"precond", " ", "=", 
