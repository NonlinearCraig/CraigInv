       RowBox[{
        RowBox[{"-", "x3"}], "+", 
        RowBox[{"0.5", "*", 
         RowBox[{"x2", "^", "2"}]}], "+", "1"}], "<=", "0"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"inv", " ", "=", " ", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "35.5223930914"}], "+", 
