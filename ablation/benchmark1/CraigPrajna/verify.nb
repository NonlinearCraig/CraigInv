        RowBox[{"0.876617672694", "*", "x2", "*", "x3"}]}], ">=", "0"}]}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"v1", "=", 
      RowBox[{"FindInstance", "[", 
       RowBox[{
        RowBox[{"domain", "&&", "precond", "&&", 
         RowBox[{"Not", "[", "inv", "]"}]}], ",", "vars"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"v2", "=", 
      RowBox[{"FindInstance", "[", 
