Cell[BoxData[
 RowBox[{
  RowBox[{"verifyResult", "[", 
   RowBox[{
   "precondition_", ",", "invariant_", ",", "guardcond_", ",", "loopcond_", 
    ",", "postcondition_", ",", "f_", ",", "vars_", ",", "domain_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"ce1", ",", "ce2", ",", "ce3"}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"ce1", "=", 
      RowBox[{"FindInstance", "[", 
       RowBox[{
        RowBox[{"Not", "[", 
         RowBox[{"Implies", "[", 
          RowBox[{
           RowBox[{"domain", "&&", "precondition"}], ",", "invariant"}], 
          "]"}], "]"}], ",", "vars"}], "]"}]}], ";", 
     RowBox[{"ce2", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"FindInstance", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"Implies", "[", 
            RowBox[{
             RowBox[{"domain", "&&", "invariant", "&&", 
              RowBox[{"guardcond", "\[LessEqual]", "0"}], "&&", 
              RowBox[{"And", "@@", 
               RowBox[{"(", 
                RowBox[{
                 RowBox[{
                  RowBox[{"LessEqual", "[", 
                   RowBox[{"#", ",", "0"}], "]"}], "&"}], "/@", 
                 RowBox[{"Flatten", "[", 
                  RowBox[{"{", 
                   RowBox[{"loopcond", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "}"}], "]"}]}], ")"}]}]}],
              ",", 
             RowBox[{"invariantnext", "=", 
              RowBox[{"invariant", "/.", 
               RowBox[{"Table", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"vars", "[", 
                   RowBox[{"[", "j", "]"}], "]"}], "\[Rule]", 
                  RowBox[{
                   RowBox[{"f", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], "[", 
                   RowBox[{"[", "j", "]"}], "]"}]}], ",", 
                 RowBox[{"{", 
                  RowBox[{"j", ",", "1", ",", 
                   RowBox[{"Length", "[", "vars", "]"}]}], "}"}]}], 
                "]"}]}]}]}], "]"}], "]"}], ",", "vars"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", 
          RowBox[{"Length", "[", "loopcond", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"ce3", "=", 
      RowBox[{"FindInstance", "[", 
       RowBox[{
        RowBox[{"Not", "[", 
         RowBox[{"Implies", "[", 
          RowBox[{
           RowBox[{"domain", "&&", "invariant", "&&", 
            RowBox[{"guardcond", ">", "0"}]}], ",", "postcondition"}], "]"}], 
         "]"}], ",", "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"ce1", ",", "ce2", ",", "ce3"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Length", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Join", "[", 
           RowBox[{"ce1", ",", "ce2", ",", "ce3"}], "]"}], "]"}], "]"}], 
        "\[Equal]", "0"}], ",", " ", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Verified.\>\"", "]"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Numerical Error Deteced.\>\"", "]"}]}], 
      "\[IndentingNewLine]", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
